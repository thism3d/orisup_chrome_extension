{
  "name": "orlenbd-marketplace",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build:vite": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --external:vite --external:@vitejs/plugin-react --bundle --format=esm --outdir=dist",
    "build": "npm run build:vite && npm run build:server",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "admin:upsert": "tsx scripts/upsert-platform-admin.ts",
    "db:backfill-actors": "tsx scripts/backfill-creator-handler.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^3.10.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.60.5",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.2.0",
    "connect-pg-simple": "^10.0.0",
    "dompurify": "^3.4.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "emailjs": "^5.0.0",
    "express": "^4.21.2",
    "express-session": "^1.18.2",
    "google-auth-library": "^10.6.2",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "puppeteer-core": "^25.0.2",
    "quill": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.55.0",
    "react-quill": "^2.0.0",
    "recharts": "^2.15.4",
    "sharp": "^0.33.5",
    "swagger-ui-dist": "^5.32.4",
    "swagger-ui-react": "^5.32.4",
    "swiper": "^12.1.3",
    "wouter": "^3.3.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/dompurify": "^3.0.5",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.16.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vite": "^5.4.20"

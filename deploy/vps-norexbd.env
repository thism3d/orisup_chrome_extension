# Copy to /var/www/norexbd/.env — replace secrets and run: npm run admin:upsert && pm2 restart norexbd
# PostgreSQL
DATABASE_URL=postgresql://norexbd_user:YOUR_DB_PASSWORD@127.0.0.1:5432/norexbd_db

# Public URL (no trailing slash)
PUBLIC_SITE_URL=https://norexbd.com
VITE_PUBLIC_SITE_URL=https://norexbd.com

# Session signing (keep your existing value if already deployed)
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Must match tunnel / PM2
PORT=5026

SECURE_COOKIES=true
ORLENBD_UPLOADS_DIR=/var/www/norexbd/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TIMEOUT_MS=18000

# Platform admin → https://norexbd.com/admin
PLATFORM_ADMIN_EMAIL=admin@norexbd.com
PLATFORM_ADMIN_PASSWORD='your-strong-unique-password'

# Default storefront branding (distinct from Orlenbd — used until Admin → Settings saves overrides)
DEFAULT_SITE_DISPLAY_NAME=Norexbd
DEFAULT_SITE_TITLE=Norexbd — Modern retail in Bangladesh | Curated deals & trusted stores
DEFAULT_SITE_DESCRIPTION=Shop curated products from vetted vendors across Bangladesh. A streamlined storefront for clear prices, dependable fulfilment, and a calmer checkout — Norexbd is built for shoppers who want quality without the clutter.
DEFAULT_SITE_KEYWORDS=norexbd, norex bd, bangladesh ecommerce, trusted online store, curated marketplace, dhaka shopping, secure checkout, vendor marketplace, retail bangladesh, fast delivery
DEFAULT_STOREFRONT_UI_TEMPLATE=norexbd
DEFAULT_STOREFRONT_THEME=theme2

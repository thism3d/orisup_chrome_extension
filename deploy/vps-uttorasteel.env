# Copy to /var/www/uttorasteel/.env — replace secrets and run: npm run admin:upsert && ./deploy.sh
# PostgreSQL (create user/db first; isolated from other brand DBs)
DATABASE_URL=postgresql://uttora:STRONG_PASS@127.0.0.1:5432/uttorasteel

# Public URL (no trailing slash)
PUBLIC_SITE_URL=https://uttorasteel.com
VITE_PUBLIC_SITE_URL=https://uttorasteel.com

# Session signing (unique per install; openssl rand -hex 32)
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Must match Cloudflare tunnel / PM2 (orlenbd=5025, norexbd=5026, orynbd=5027, masumtraders=5028)
PORT=5029

ENFORCE_CANONICAL_ORIGIN=true
SECURE_COOKIES=true
ORLENBD_UPLOADS_DIR=/var/www/uttorasteel/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TIMEOUT_MS=18000

# Platform admin → https://uttorasteel.com/admin
PLATFORM_ADMIN_EMAIL=admin@uttorasteel.com
PLATFORM_ADMIN_PASSWORD='your-strong-unique-password'

# Default storefront branding (used until Admin → Settings saves overrides)
DEFAULT_SITE_DISPLAY_NAME=UttoraSteel
DEFAULT_SITE_TITLE=UttoraSteel — Steel furniture, beds & workshop goods in Bangladesh
DEFAULT_SITE_DESCRIPTION=Shop steel beds, chairs, tables, kitchen racks, office furniture, and workshop essentials from verified makers. Industrial quality for home and business — UttoraSteel.
DEFAULT_SITE_KEYWORDS=uttorasteel, uttora steel, bangladesh steel furniture, steel bed, metal chair, workshop furniture, kitchen steel rack, office steel table, fabricated steel, dhaka steel shop
DEFAULT_STOREFRONT_UI_TEMPLATE=uttorasteel
DEFAULT_STOREFRONT_THEME=theme5

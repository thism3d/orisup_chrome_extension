# Copy to /var/www/orlenbd/.env — replace secrets and run: npm run admin:upsert && pm2 restart orlenbd
# PostgreSQL
DATABASE_URL=postgresql://orlenbd_user:YOUR_DB_PASSWORD@127.0.0.1:5432/orlenbd_db

# Public URL (no trailing slash)
PUBLIC_SITE_URL=https://orlenbd.com
VITE_PUBLIC_SITE_URL=https://orlenbd.com

# Session signing (keep your existing value if already deployed)
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Must match tunnel / PM2
PORT=5025

SECURE_COOKIES=true
ORLENBD_UPLOADS_DIR=/var/www/orlenbd/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TIMEOUT_MS=18000

# Platform admin → https://orlenbd.com/admin
PLATFORM_ADMIN_EMAIL=admin@orlenbd.com
PLATFORM_ADMIN_PASSWORD='your-strong-unique-password'

# Default storefront branding (used until Admin → Settings saves overrides)
DEFAULT_SITE_DISPLAY_NAME=Orlenbd
DEFAULT_SITE_TITLE=Orlenbd — Bangladesh marketplace | Electronics, fashion & home
DEFAULT_SITE_DESCRIPTION=Discover deals on electronics, fashion, home essentials, and daily needs. Verified sellers, transparent pricing, and cash on delivery where available — shop the Orlenbd marketplace with confidence.
DEFAULT_SITE_KEYWORDS=orlenbd, orlen bd, bangladesh online shopping, multi vendor marketplace, electronics bangladesh, fashion dhaka, chattogram shopping, COD delivery, verified sellers, online bazaar
DEFAULT_STOREFRONT_UI_TEMPLATE=orlenbd
DEFAULT_STOREFRONT_THEME=theme1

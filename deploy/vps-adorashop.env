# Copy to /var/www/adorashopbd/.env — replace secrets, then on server: ./deploy.sh
# PostgreSQL (create DB/user first, e.g. createdb / CREATE USER mirroring other shops)
DATABASE_URL=postgresql://adorashop_user:YOUR_DB_PASSWORD@127.0.0.1:5432/adorashop_db

# Public URL (no trailing slash) — subdomain on Orlenbd
PUBLIC_SITE_URL=https://adora.orlenbd.com
VITE_PUBLIC_SITE_URL=https://adora.orlenbd.com

# Session signing
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Must match tunnel / PM2 (pick a free port on the VPS)
PORT=5030

SECURE_COOKIES=true
ORLENBD_UPLOADS_DIR=/var/www/adorashopbd/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Platform admin → https://adora.orlenbd.com/admin
PLATFORM_ADMIN_EMAIL=admin@adora.orlenbd.com
PLATFORM_ADMIN_PASSWORD='your-strong-unique-password'

# Default storefront: Adora Shop — fashion template + rose palette (override anytime in Admin → Settings)
DEFAULT_SITE_DISPLAY_NAME=Adora Shop
DEFAULT_SITE_TITLE=Adora Shop — Fashion & lifestyle on Orlenbd
DEFAULT_SITE_DESCRIPTION=Elevate your everyday style — curated clothing, shoes, and accessories from trusted sellers on Orlenbd. Safe payments and quick checkout.
DEFAULT_SITE_KEYWORDS=adora shop, orlenbd, fashion bangladesh, clothing online, shoes, lifestyle, apparel
DEFAULT_STOREFRONT_UI_TEMPLATE=adorashop
DEFAULT_STOREFRONT_THEME=theme6

# Copy to /var/www/orynbd/.env — replace secrets and run: npm run admin:upsert && ./deploy.sh
# PostgreSQL (create user/db first; must be isolated from orlenbd_db / norexbd_db)
DATABASE_URL=postgresql://orynbd_user:YOUR_DB_PASSWORD@127.0.0.1:5432/orynbd_db

# Public URL (no trailing slash)
PUBLIC_SITE_URL=https://orynbd.com
VITE_PUBLIC_SITE_URL=https://orynbd.com

# Session signing (unique per install; openssl rand -hex 32)
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Must match Cloudflare tunnel / PM2 (orlenbd=5025, norexbd=5026, orynbd=5027)
PORT=5027

SECURE_COOKIES=true
ORLENBD_UPLOADS_DIR=/var/www/orynbd/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TIMEOUT_MS=18000

# Platform admin → https://orynbd.com/admin
PLATFORM_ADMIN_EMAIL=admin@orynbd.com
PLATFORM_ADMIN_PASSWORD='your-strong-unique-password'

# Default storefront branding (distinct — used until Admin → Settings saves overrides)
DEFAULT_SITE_DISPLAY_NAME=Orynbd
DEFAULT_SITE_TITLE=Orynbd — Shop smart in Bangladesh | Deals, brands & fast checkout
DEFAULT_SITE_DESCRIPTION=Browse trending categories, trusted sellers, and clear pricing on Orynbd. Built for quick discovery and a smooth path to checkout — your Bangladesh marketplace for everyday and premium finds.
DEFAULT_SITE_KEYWORDS=orynbd, oryn bd, bangladesh online shop, marketplace bangladesh, dhaka ecommerce, chattogram delivery, multi vendor, flash deals, brand stores, secure shopping
DEFAULT_STOREFRONT_UI_TEMPLATE=orynbd
DEFAULT_STOREFRONT_THEME=theme3

# Copy to /var/www/masumtraders/.env — replace secrets and run: npm run admin:upsert && ./deploy.sh
# PostgreSQL (create user/db first; isolated from other brand DBs)
DATABASE_URL=postgresql://masum:STRONG_PASS@127.0.0.1:5432/masumtraders

# Public URL (no trailing slash)
PUBLIC_SITE_URL=https://masumtradersbd.com
VITE_PUBLIC_SITE_URL=https://masumtradersbd.com

# Session signing (unique per install; openssl rand -hex 32)
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Must match Cloudflare tunnel / PM2
PORT=5028

ENFORCE_CANONICAL_ORIGIN=true
SECURE_COOKIES=true
ORLENBD_UPLOADS_DIR=/var/www/masumtraders/uploads
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_TIMEOUT_MS=18000

# Platform admin → https://masumtradersbd.com/admin
PLATFORM_ADMIN_EMAIL=admin@masumtradersbd.com
PLATFORM_ADMIN_PASSWORD='your-strong-unique-password'

# Default storefront branding (used until Admin → Settings saves overrides)
DEFAULT_SITE_DISPLAY_NAME=MasumTraders
DEFAULT_SITE_TITLE=MasumTraders — Fresh grocery essentials in Bangladesh
DEFAULT_SITE_DESCRIPTION=Shop daily essentials, pantry staples, snacks, beverages, and household needs from trusted sellers. MasumTraders brings a grocery-first shopping flow with clear prices and reliable delivery.
DEFAULT_SITE_KEYWORDS=masumtraders, masum traders bd, bangladesh grocery online, daily essentials, pantry staples, rice oil snacks, household items, dhaka grocery delivery, trusted marketplace
DEFAULT_STOREFRONT_UI_TEMPLATE=masumtraders
DEFAULT_STOREFRONT_THEME=theme4
